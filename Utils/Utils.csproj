<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<EnablePreviewFeatures>True</EnablePreviewFeatures>
		<AllowUnsafeBlocks>True</AllowUnsafeBlocks>
		<Copyright>Olivier MARTY 2025</Copyright>
		<Authors>Olivier MARTY</Authors>
		<Company>Olivier MARTY</Company>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<PackageId>omy.Utils</PackageId>
		<PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<Version>1.2.1</Version>
		<Description>Shared foundation package for the omy.Utils ecosystem, including collections, expressions, streams, security, reflection, formatting, and general-purpose .NET utility helpers.</Description>
		<RepositoryUrl>https://github.com/warny/All-purpose-Utilities</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageProjectUrl>https://github.com/warny/All-purpose-Utilities</PackageProjectUrl>
		<PackageTags>omy;utilities;helpers;collections;expressions;streams;security;reflection</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<Compile Remove="Globalization\**" />
		<Compile Remove="Mathematics\NumberToStringConverter.cs" />
		<Compile Remove="Mathematics\NumberToStringConverter.Globalization.cs" />
		<Compile Remove="Mathematics\INumberToStringConverter.cs" />
		<Compile Remove="Mathematics\NumberConverterConfiguration.cs" />
		<Compile Remove="Mathematics\NumberConverterResources.Designer.cs" />
		<EmbeddedResource Remove="Globalization\**" />
		<EmbeddedResource Remove="Mathematics\NumberConverterResources.resx" />
		<None Remove="Globalization\**" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Utils.Parser\Utils.Parser.csproj" />
                <PackageReference Include="System.Runtime" Version="4.3.1" />
                <PackageReference Include="System.Text.Encoding.CodePages" Version="9.0.6" />
        </ItemGroup>

	<ItemGroup>
		<None Include="Objects\DateFormulaConfigurations\DateFormulaConfiguration.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>

        <ItemGroup>
                <None Include="README.md" Pack="true" PackagePath="\" />
        </ItemGroup>
</Project>
