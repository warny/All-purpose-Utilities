<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<!-- TargetFramework remains net8.0 until dependent projects (Utils.Imaging, Utils.Geography,
		     Utils.VirtualMachine, Utils.Parser.Expressions) are also upgraded to net9.0 (#27).
		     Upgrading Utils in isolation breaks NU1201 compatibility checks. -->
		<TargetFramework>net8.0</TargetFramework>
		<!-- AllowUnsafeBlocks is required: unsafe code is used in Arrays, Collections, and String
		     helpers for performance-sensitive operations (pointer arithmetic, Span<T> interop).
		     This cannot be removed without refactoring those files (#27). -->
		<AllowUnsafeBlocks>True</AllowUnsafeBlocks>
		<Copyright>Olivier MARTY 2025</Copyright>
		<Authors>Olivier MARTY</Authors>
		<Company>Olivier MARTY</Company>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<PackageId>omy.Utils</PackageId>
		<PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<Version>1.2.1</Version>
		<Description>Shared foundation package for the omy.Utils ecosystem, including collections, expressions, streams, security, reflection, formatting, and general-purpose .NET utility helpers.</Description>
		<RepositoryUrl>https://github.com/warny/All-purpose-Utilities</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageProjectUrl>https://github.com/warny/All-purpose-Utilities</PackageProjectUrl>
		<PackageTags>omy;utilities;helpers;collections;expressions;streams;security;reflection</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<Compile Remove="Globalization\**" />
<EmbeddedResource Remove="Globalization\**" />
		<None Remove="Globalization\**" />
	</ItemGroup>

	<ItemGroup>
		<!-- Utils.Parser project reference was removed: Utils source files have no 'using Utils.Parser'
		     dependency. The reference was an inverted dependency that pulled the parser into all
		     consumers of the base package (#28). -->
		<!-- System.Runtime is a framework meta-package, no need to reference it explicitly on net9.0 (#27). -->
                <PackageReference Include="System.Text.Encoding.CodePages" Version="9.0.6" />
        </ItemGroup>

	<ItemGroup>
		<None Include="Objects\DateFormulaConfigurations\DateFormulaConfiguration.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>

        <ItemGroup>
                <None Include="README.md" Pack="true" PackagePath="\" />
        </ItemGroup>
</Project>
