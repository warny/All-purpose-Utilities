<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<EnablePreviewFeatures>True</EnablePreviewFeatures>
		<IsPackable>false</IsPackable>
		<IsTestProject>true</IsTestProject>
		<Authors>Olivier MARTY</Authors>
		<Description>Functional and integration tests for all utilities. Covers network protocols, font parsing, OData, parser integration, and file I/O.</Description>
		<RootNamespace>UtilsTest</RootNamespace>
		<NoWarn>$(NoWarn);1591;CS0612;CS0618;CS8618;CS8625;CS8602;CS8603;CS8604;CS8600;CS8767;CS8601;CS8765;CS8620;CS8619;CS8629;CS8714;CS8622;CS8621</NoWarn>
		<RollForward>Major</RollForward>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="coverlet.collector" Version="6.0.4">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
		<PackageReference Include="Moq" Version="4.20.72" />
		<PackageReference Include="MSTest.TestAdapter" Version="3.9.3" />
		<PackageReference Include="MSTest.TestFramework" Version="3.9.3" />
		<PackageReference Include="System.Drawing.Common" Version="9.0.6" />
		<PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Utils.Net\Utils.Net.csproj" />
		<ProjectReference Include="..\Utils.Data\Utils.Data.csproj" />
		<ProjectReference Include="..\Utils.Fonts\Utils.Fonts.csproj" />
		<ProjectReference Include="..\Utils.Geography\Utils.Geography.csproj" />
		<ProjectReference Include="..\Utils.IO\Utils.IO.csproj" />
		<ProjectReference Include="..\Utils.Mathematics\Utils.Mathematics.csproj" />
		<ProjectReference Include="..\Utils.NumberToString\Utils.NumberToString.csproj" />
		<ProjectReference Include="..\Utils.Collections\Utils.Collections.csproj" />
		<ProjectReference Include="..\Utils.Reflection\Utils.Reflection.csproj" />
		<ProjectReference Include="..\Utils.VirtualMachine\Utils.VirtualMachine.csproj" />
		<ProjectReference Include="..\Utils.Xml\Utils.Xml.csproj" />
		<ProjectReference Include="..\Utils\Utils.csproj" />
		<ProjectReference Include="..\Utils.Imaging\Utils.Imaging.csproj" />
		<ProjectReference Include="..\Utils.DependencyInjection\Utils.DependencyInjection.csproj" />
		<ProjectReference Include="..\Utils.DependencyInjection.Generators\Utils.DependencyInjection.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
		<ProjectReference Include="..\Utils.IO.Serialization.Generators\Utils.IO.Serialization.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
		<ProjectReference Include="..\Utils.Parser.Generators\Utils.Parser.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="true" />
		<ProjectReference Include="..\Utils.Parser.Diagnostics\Utils.Parser.Diagnostics.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
		<ProjectReference Include="..\Utils.OData.Generators\Utils.OData.Generators.csproj" />
		<ProjectReference Include="..\Utils.OData\Utils.OData.csproj" />
		<ProjectReference Include="..\Utils.Parser\Utils.Parser.csproj" />
		<ProjectReference Include="..\Utils.Parser.VisualStudio\Utils.Parser.VisualStudio.csproj" />
		<ProjectReference Include="..\Utils.Expressions.CSyntax\Utils.Expressions.CSyntax.csproj" />
		<ProjectReference Include="..\Utils.Expressions.VBSyntax\Utils.Expressions.VBSyntax.csproj" />
		<ProjectReference Include="..\Utils.Parser.Expressions\Utils.Parser.Expressions.csproj" />
	</ItemGroup>

	<ItemGroup>
		<Compile Update="Fonts\Fonts.Designer.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>Fonts.resx</DependentUpon>
		</Compile>
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Update="Fonts\Fonts.resx">
			<Generator>ResXFileCodeGenerator</Generator>
			<LastGenOutput>Fonts.Designer.cs</LastGenOutput>
		</EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<None Update="Fonts\arial.ttf">
			<CopyToOutputDirectory>Never</CopyToOutputDirectory>
		</None>
	</ItemGroup>

</Project>
