<?xml version="1.0" encoding="utf-8" ?>
<Numbers xmlns="Utils/NumberConvertionConfiguration.xsd">
    <Language
        groupSize="3"
        separator=" "
        groupSeparator=""
        zero="صفر"
        minus="سالب *"
        decimalSeparator="فاصل"
        fractionSeparator="على"
        maxNumber="999999999"
    >
        <Culture>AR</Culture>
        <Groups>
            <Group level="1">
                <Digit digit="0" string="" />
                <Digit digit="1" string="واحد" />
                <Digit digit="2" string="اثنان" />
                <Digit digit="3" string="ثلاثة" />
                <Digit digit="4" string="أربعة" />
                <Digit digit="5" string="خمسة" />
                <Digit digit="6" string="ستة" />
                <Digit digit="7" string="سبعة" />
                <Digit digit="8" string="ثمانية" />
                <Digit digit="9" string="تسعة" />
            </Group>
            <Group level="2">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="عشرة" buildString="عشرة *" />
                <Digit digit="2" string="عشرون" buildString="عشرون *" />
                <Digit digit="3" string="ثلاثون" buildString="ثلاثون *" />
                <Digit digit="4" string="أربعون" buildString="أربعون *" />
                <Digit digit="5" string="خمسون" buildString="خمسون *" />
                <Digit digit="6" string="ستون" buildString="ستون *" />
                <Digit digit="7" string="سبعون" buildString="سبعون *" />
                <Digit digit="8" string="ثمانون" buildString="ثمانون *" />
                <Digit digit="9" string="تسعون" buildString="تسعون *" />
            </Group>
            <Group level="3">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="مائة" buildString="مائة *" />
                <Digit digit="2" string="مائتان" buildString="مائتان *" />
                <Digit digit="3" string="ثلاثمائة" buildString="ثلاثمائة *" />
                <Digit digit="4" string="أربعمائة" buildString="أربعمائة *" />
                <Digit digit="5" string="خمسمائة" buildString="خمسمائة *" />
                <Digit digit="6" string="ستمائة" buildString="ستمائة *" />
                <Digit digit="7" string="سبعمائة" buildString="سبعمائة *" />
                <Digit digit="8" string="ثمانمائة" buildString="ثمانمائة *" />
                <Digit digit="9" string="تسعمائة" buildString="تسعمائة *" />
            </Group>
        </Groups>
        <NumberScale firstLetterUpperCase="false">
            <StaticNames>
                <Scale value="0" string="" />
                <Scale value="1" string="ألف" />
            </StaticNames>
            <Suffixes>
                <Suffix>مليون</Suffix>
            </Suffixes>
        </NumberScale>
        <Exceptions />
        <Ordinals>
            <!-- Masculin indéfini, forme courte (sans article) — les ordinaux arabes
                 sont indépendants des cardinaux et varient en genre avec le nom -->
            <OrdinalException value="1"  string="أول" />
            <OrdinalException value="2"  string="ثانٍ" />
            <OrdinalException value="3"  string="ثالث" />
            <OrdinalException value="4"  string="رابع" />
            <OrdinalException value="5"  string="خامس" />
            <OrdinalException value="6"  string="سادس" />
            <OrdinalException value="7"  string="سابع" />
            <OrdinalException value="8"  string="ثامن" />
            <OrdinalException value="9"  string="تاسع" />
            <OrdinalException value="10" string="عاشر" />
            <OrdinalVariants>
                <!-- Forme féminine (muʾannath) pour 1-10 ; au-delà de 10 aucune exception n'est définie -->
                <Variant type="gender" variant="muʾannath">
                    <OrdinalException value="1"  string="أولى"   />
                    <OrdinalException value="2"  string="ثانية"  />
                    <OrdinalException value="3"  string="ثالثة"  />
                    <OrdinalException value="4"  string="رابعة"  />
                    <OrdinalException value="5"  string="خامسة"  />
                    <OrdinalException value="6"  string="سادسة"  />
                    <OrdinalException value="7"  string="سابعة"  />
                    <OrdinalException value="8"  string="ثامنة"  />
                    <OrdinalException value="9"  string="تاسعة"  />
                    <OrdinalException value="10" string="عاشرة"  />
                </Variant>
            </OrdinalVariants>
        </Ordinals>
        <Variants>
            <Dimension name="gender" values="muʾakar,muʾannath" />
        </Variants>
    </Language>
</Numbers>
