<?xml version="1.0" encoding="utf-8" ?>
<Numbers xmlns="Utils/NumberConvertionConfiguration.xsd">
    <Language
        groupSize="3"
        separator=" "
        groupSeparator=""
        zero="אפס"
        minus="מינוס *"
        decimalSeparator="נקודה"
        fractionSeparator="על"
        maxNumber="999999999"
    >
        <Culture>HE</Culture>
        <Groups>
            <Group level="1">
                <Digit digit="0" string="" />
                <Digit digit="1" string="אחד" />
                <Digit digit="2" string="שתיים" />
                <Digit digit="3" string="שלוש" />
                <Digit digit="4" string="ארבע" />
                <Digit digit="5" string="חמש" />
                <Digit digit="6" string="שש" />
                <Digit digit="7" string="שבע" />
                <Digit digit="8" string="שמונה" />
                <Digit digit="9" string="תשע" />
            </Group>
            <Group level="2">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="עשר" buildString="עשר *" />
                <Digit digit="2" string="עשרים" buildString="עשרים *" />
                <Digit digit="3" string="שלושים" buildString="שלושים *" />
                <Digit digit="4" string="ארבעים" buildString="ארבעים *" />
                <Digit digit="5" string="חמישים" buildString="חמישים *" />
                <Digit digit="6" string="שישים" buildString="שישים *" />
                <Digit digit="7" string="שבעים" buildString="שבעים *" />
                <Digit digit="8" string="שמונים" buildString="שמונים *" />
                <Digit digit="9" string="תשעים" buildString="תשעים *" />
            </Group>
            <Group level="3">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="מאה" buildString="מאה *" />
                <Digit digit="2" string="מאתיים" buildString="מאתיים *" />
                <Digit digit="3" string="שלוש מאות" buildString="שלוש מאות *" />
                <Digit digit="4" string="ארבע מאות" buildString="ארבע מאות *" />
                <Digit digit="5" string="חמש מאות" buildString="חמש מאות *" />
                <Digit digit="6" string="שש מאות" buildString="שש מאות *" />
                <Digit digit="7" string="שבע מאות" buildString="שבע מאות *" />
                <Digit digit="8" string="שמונה מאות" buildString="שמונה מאות *" />
                <Digit digit="9" string="תשע מאות" buildString="תשע מאות *" />
            </Group>
        </Groups>
        <NumberScale firstLetterUpperCase="false">
            <StaticNames>
                <Scale value="0" string="" />
                <Scale value="1" string="אלף" />
            </StaticNames>
            <Suffixes>
                <Suffix>מיליון</Suffix>
            </Suffixes>
        </NumberScale>
        <Exceptions />
        <!--
          Hebrew ordinals exist only for 1-10; higher ordinals are expressed
          as cardinals in practice. The default (zachar / standalone) forms are
          masculine; the nekeva variant provides feminine forms.
        -->
        <!--
          Ordinals 1-10 — forms listed in Dimension order: standalone, zachar, nekeva.
          standalone and zachar share the same forms (both use the masculine ordinal);
          nekeva carries the feminine form. The first entry also serves as the default
          when ConvertOrdinal is called without an explicit gender variant.
        -->
        <Ordinals>
            <OrdinalException value="1">  <Variant type="gender" forms="ראשון,ראשון,ראשונה"   /></OrdinalException>
            <OrdinalException value="2">  <Variant type="gender" forms="שני,שני,שנייה"         /></OrdinalException>
            <OrdinalException value="3">  <Variant type="gender" forms="שלישי,שלישי,שלישית"   /></OrdinalException>
            <OrdinalException value="4">  <Variant type="gender" forms="רביעי,רביעי,רביעית"   /></OrdinalException>
            <OrdinalException value="5">  <Variant type="gender" forms="חמישי,חמישי,חמישית"   /></OrdinalException>
            <OrdinalException value="6">  <Variant type="gender" forms="שישי,שישי,שישית"       /></OrdinalException>
            <OrdinalException value="7">  <Variant type="gender" forms="שביעי,שביעי,שביעית"   /></OrdinalException>
            <OrdinalException value="8">  <Variant type="gender" forms="שמיני,שמיני,שמינית"   /></OrdinalException>
            <OrdinalException value="9">  <Variant type="gender" forms="תשיעי,תשיעי,תשיעית"   /></OrdinalException>
            <OrdinalException value="10"> <Variant type="gender" forms="עשירי,עשירי,עשירית"   /></OrdinalException>
        </Ordinals>
        <Variants>
            <!--
              In Hebrew, digits 3-10 exhibit a "gender paradox":
              the grammatically feminine form (-ה) is used with masculine nouns
              (zachar), and the form without ה is used with feminine nouns (nekeva).

              The "standalone" mode (default) reproduces the current configuration
              behaviour: forms 3-9 are compatible with feminine nouns and abstract
              counting, but 1 is in its masculine form (אחד).

              ZACHAR (masculine nouns): 2→שניים, 3-9 add ה (except 8, invariable),
                10→עשרה. Hundreds (שלוש מאות etc.) remain unchanged because מאות
                is feminine: the unit form is already correct there.
              NEKEVA (feminine nouns): only 1 changes (אחד→אחת); forms 2-10
                are already correct for feminine nouns in the configuration.

              Limitation: the multiplier before אלף (thousands) is not converted
              because "אלף" is the last word, not the unit.
            -->
            <Dimension name="gender" localName="מגדר" values="standalone,zachar,nekeva" />

            <!-- ── Zachar (masculine nouns) ──────────────────────────────── -->
            <Variant type="gender" variant="zachar">
                <!-- Units (LastWord: does not affect the interior of compound hundreds) -->
                <Replacement oldValue="שתיים" newValue="שניים"  scope="LastWord" />
                <Replacement oldValue="שלוש"  newValue="שלושה" scope="LastWord" />
                <Replacement oldValue="ארבע"  newValue="ארבעה" scope="LastWord" />
                <Replacement oldValue="חמש"   newValue="חמישה" scope="LastWord" />
                <Replacement oldValue="שש"    newValue="שישה"  scope="LastWord" />
                <Replacement oldValue="שבע"   newValue="שבעה"  scope="LastWord" />
                <Replacement oldValue="תשע"   newValue="תשעה"  scope="LastWord" />
                <!-- standalone 10 -->
                <Replacement oldValue="עשר"   newValue="עשרה"  scope="LastWord" />
            </Variant>

            <!-- ── Nekeva (feminine nouns) ───────────────────────────────── -->
            <Variant type="gender" variant="nekeva">
                <!-- Only 1 changes; forms 2-9 are already correct for feminine nouns -->
                <Replacement oldValue="אחד" newValue="אחת" scope="LastWord" />
            </Variant>
        </Variants>
    </Language>
</Numbers>
