<?xml version="1.0" encoding="utf-8" ?>
<Numbers xmlns="Utils/NumberConvertionConfiguration.xsd">
    <Language
        groupSize="3"
        separator=" "
        groupSeparator=""
        zero="nul"
        minus="min *"
        decimalSeparator="komma"
        fractionSeparator="op"
    >
        <Culture>NL</Culture>
        <Groups>
            <Group level="1">
                <Digit digit="0" string="" />
                <Digit digit="1" string="een" />
                <Digit digit="2" string="twee" />
                <Digit digit="3" string="drie" />
                <Digit digit="4" string="vier" />
                <Digit digit="5" string="vijf" />
                <Digit digit="6" string="zes" />
                <Digit digit="7" string="zeven" />
                <Digit digit="8" string="acht" />
                <Digit digit="9" string="negen" />
            </Group>
            <Group level="2">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="tien" buildString="tien *" />
                <Digit digit="2" string="twintig" buildString="*entwintig" />
                <Digit digit="3" string="dertig" buildString="*endertig" />
                <Digit digit="4" string="veertig" buildString="*enveertig" />
                <Digit digit="5" string="vijftig" buildString="*envijftig" />
                <Digit digit="6" string="zestig" buildString="*enzestig" />
                <Digit digit="7" string="zeventig" buildString="*enzeventig" />
                <Digit digit="8" string="tachtig" buildString="*entachtig" />
                <Digit digit="9" string="negentig" buildString="*ennegentig" />
            </Group>
            <Group level="3">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="honderd" buildString="honderd *" />
                <Digit digit="2" string="tweehonderd" buildString="tweehonderd *" />
                <Digit digit="3" string="driehonderd" buildString="driehonderd *" />
                <Digit digit="4" string="vierhonderd" buildString="vierhonderd *" />
                <Digit digit="5" string="vijfhonderd" buildString="vijfhonderd *" />
                <Digit digit="6" string="zeshonderd" buildString="zeshonderd *" />
                <Digit digit="7" string="zevenhonderd" buildString="zevenhonderd *" />
                <Digit digit="8" string="achthonderd" buildString="achthonderd *" />
                <Digit digit="9" string="negenhonderd" buildString="negenhonderd *" />
            </Group>
        </Groups>
        <NumberScale firstLetterUpperCase="false">
            <StaticNames>
                <Scale value="0" string="" />
                <Scale value="1" string="duizend" />
            </StaticNames>
            <Suffixes>
                <Suffix>miljoen</Suffix>
            </Suffixes>
        </NumberScale>
        <Replacements>
            <Replacement oldValue="een duizend" newValue="duizend" onScale="1" onValue="1" />
        </Replacements>
        <Exceptions>
            <Number value="11" string="elf" />
            <Number value="12" string="twaalf" />
            <Number value="13" string="dertien" />
            <Number value="14" string="veertien" />
            <Number value="15" string="vijftien" />
            <Number value="16" string="zestien" />
            <Number value="17" string="zeventien" />
            <Number value="18" string="achttien" />
            <Number value="19" string="negentien" />
        </Exceptions>
        <!--
          Dutch ordinal suffix is -de for most words and -ste for words ending
          in a vowel or when the stem already ends in -t. In practice all round
          tens (twintig, dertig, …), compounds fused with them (eenentwintig,
          tweeëndertig, …), and scale words (honderd, duizend) take -ste, while
          units 2-7, 9 and teens 10-19 need -de. We model this with suffix "ste"
          and explicit Ordinal rules for every word that takes -de instead.
          "acht" correctly gets "achtste" from the suffix alone.
        -->
        <Ordinals suffix="ste">
            <OrdinalException value="1" string="eerste" />
            <Ordinal from="een"       to="eerste" />
            <Ordinal from="twee"      to="tweede" />
            <Ordinal from="drie"      to="derde" />
            <Ordinal from="vier"      to="vierde" />
            <Ordinal from="vijf"      to="vijfde" />
            <Ordinal from="zes"       to="zesde" />
            <Ordinal from="zeven"     to="zevende" />
            <Ordinal from="negen"     to="negende" />
            <Ordinal from="tien"      to="tiende" />
            <Ordinal from="elf"       to="elfde" />
            <Ordinal from="twaalf"    to="twaalfde" />
            <Ordinal from="dertien"   to="dertiende" />
            <Ordinal from="veertien"  to="veertiende" />
            <Ordinal from="vijftien"  to="vijftiende" />
            <Ordinal from="zestien"   to="zestiende" />
            <Ordinal from="zeventien" to="zeventiende" />
            <Ordinal from="achttien"  to="achttiende" />
            <Ordinal from="negentien" to="negentiende" />
        </Ordinals>
        <YearFormat hundredWord="honderd">
            <SplitRange from="1100" to="1999" />
        </YearFormat>
    </Language>
</Numbers>
