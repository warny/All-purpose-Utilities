<?xml version="1.0" encoding="utf-8" ?>
<Numbers xmlns="Utils/NumberConvertionConfiguration.xsd">
	<!--
	  Swiss German (de-CH, de-LI) inherits all configuration from standard German (DE)
	  and overrides only the two points where Swiss German differs:

	  1. Replacements: DE uses "ein tausend" → "tausend" so 1000 = "tausend".
	     Swiss German retains "ein tausend", so <Replacements/> overrides the base
	     with an empty list.

	  2. Ordinals for 1000: because 1000 = "ein tausend" (not "tausend"), the word-rule
	     "tausend" → ordinal "tausendste" would produce the correct result anyway.
	     The explicit OrdinalException value="1000" is kept for clarity and to match the
	     expected "tausendste" form even if the base word-rule changes in the future.
	     All other ordinal exceptions, word-rules, and OrdinalVariants are inherited from DE.
	-->
	<Language baseOn="DE">
		<Culture>de-CH</Culture>
		<Culture>de-LI</Culture>
		<Replacements />
		<Ordinals>
			<OrdinalException value="1000" string="tausendste">
				<Variant type="gender" variant="maskulin">
					<Variant type="declension" variant="schwach">
						<Variant type="case" forms="tausendste,tausendsten,tausendsten,tausendsten" />
					</Variant>
					<Variant type="declension" variant="stark">
						<Variant type="case" forms="tausendster,tausendsten,tausendstem,tausendsten" />
					</Variant>
				</Variant>
				<Variant type="gender" variant="feminin">
					<Variant type="declension" variant="schwach">
						<Variant type="case" forms="tausendste,tausendste,tausendsten,tausendsten" />
					</Variant>
					<Variant type="declension" variant="stark">
						<Variant type="case" forms="tausendste,tausendste,tausendster,tausendster" />
					</Variant>
				</Variant>
				<Variant type="gender" variant="neutrum">
					<Variant type="declension" variant="schwach">
						<Variant type="case" forms="tausendste,tausendste,tausendsten,tausendsten" />
					</Variant>
					<Variant type="declension" variant="stark">
						<Variant type="case" forms="tausendstes,tausendstes,tausendstem,tausendsten" />
					</Variant>
				</Variant>
			</OrdinalException>
		</Ordinals>
	</Language>
</Numbers>
