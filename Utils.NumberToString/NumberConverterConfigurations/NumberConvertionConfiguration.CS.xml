<?xml version="1.0" encoding="utf-8" ?>
<Numbers xmlns="Utils/NumberConvertionConfiguration.xsd">
    <Language
        groupSize="3"
        separator=" "
        groupSeparator=""
        zero="nula"
        minus="minus *"
        decimalSeparator="celá"
        fractionSeparator="ku"
    >
        <Culture>CS</Culture>
        <Culture>CS-CZ</Culture>
        <Groups>
            <Group level="1">
                <Digit digit="0" string="" />
                <Digit digit="1" string="jedna" />
                <Digit digit="2" string="dva" />
                <Digit digit="3" string="tři" />
                <Digit digit="4" string="čtyři" />
                <Digit digit="5" string="pět" />
                <Digit digit="6" string="šest" />
                <Digit digit="7" string="sedm" />
                <Digit digit="8" string="osm" />
                <Digit digit="9" string="devět" />
            </Group>
            <Group level="2">
                <Digit digit="0" string="" buildString="*" />
                <!-- 11–19 are handled as Exceptions -->
                <Digit digit="1" string="deset" buildString="deset *" />
                <Digit digit="2" string="dvacet" buildString="dvacet *" />
                <Digit digit="3" string="třicet" buildString="třicet *" />
                <Digit digit="4" string="čtyřicet" buildString="čtyřicet *" />
                <Digit digit="5" string="padesát" buildString="padesát *" />
                <Digit digit="6" string="šedesát" buildString="šedesát *" />
                <Digit digit="7" string="sedmdesát" buildString="sedmdesát *" />
                <Digit digit="8" string="osmdesát" buildString="osmdesát *" />
                <Digit digit="9" string="devadesát" buildString="devadesát *" />
            </Group>
            <Group level="3">
                <Digit digit="0" string="" buildString="*" />
                <!-- Czech hundreds: sto, dvě stě, tři sta, čtyři sta, pět set … devět set -->
                <Digit digit="1" string="sto" buildString="sto *" />
                <Digit digit="2" string="dvě stě" buildString="dvě stě *" />
                <Digit digit="3" string="tři sta" buildString="tři sta *" />
                <Digit digit="4" string="čtyři sta" buildString="čtyři sta *" />
                <Digit digit="5" string="pět set" buildString="pět set *" />
                <Digit digit="6" string="šest set" buildString="šest set *" />
                <Digit digit="7" string="sedm set" buildString="sedm set *" />
                <Digit digit="8" string="osm set" buildString="osm set *" />
                <Digit digit="9" string="devět set" buildString="devět set *" />
            </Group>
        </Groups>
        <!-- Long scale with groupSeparator="li" (single l): mi+li+on=milion, mi+li+ard=miliard,
             bi+li+on=bilion, bi+li+ard=biliard, tri+li+on=trilion…
             Note: Czech uses "miliarda" (feminine) for 10^9, but "miliard" is used as invariant
             simplification since the engine does not support noun gender inflection here. -->
        <NumberScale firstLetterUpperCase="false" groupSeparator="li">
            <StaticNames>
                <Scale value="0" string="" />
                <!-- Czech: "tisíc" alone for 1000; "jedna tisíc" → "tisíc" via Replacement -->
                <Scale value="1" string="tisíc" />
            </StaticNames>
            <Suffixes>
                <Suffix>on</Suffix>
                <Suffix>ard</Suffix>
            </Suffixes>
        </NumberScale>
        <Replacements>
            <!-- Drop "jedna" before "tisíc": 1000 = "tisíc" not "jedna tisíc" -->
            <Replacement oldValue="jedna tisíc" newValue="tisíc" />
        </Replacements>
        <Exceptions>
            <Number value="11" string="jedenáct" />
            <Number value="12" string="dvanáct" />
            <Number value="13" string="třináct" />
            <Number value="14" string="čtrnáct" />
            <Number value="15" string="patnáct" />
            <Number value="16" string="šestnáct" />
            <Number value="17" string="sedmnáct" />
            <Number value="18" string="osmnáct" />
            <Number value="19" string="devatenáct" />
        </Exceptions>
    </Language>
</Numbers>
