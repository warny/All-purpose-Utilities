<?xml version="1.0" encoding="utf-8" ?>
<Numbers xmlns="Utils/NumberConvertionConfiguration.xsd">
        <Language
                groupSize="3"
                separator=" "
                groupSeparator=""
                zero="null"
                minus="minus *"
                decimalSeparator="komma"
                fractionSeparator="durch"
        >
		<Culture>DE</Culture>
		<Groups>
			<Group level="1">
				<Digit digit="0" string="" />
				<Digit digit="1" string="ein" />
				<Digit digit="2" string="zwei" />
				<Digit digit="3" string="drei" />
				<Digit digit="4" string="vier" />
				<Digit digit="5" string="fünf" />
				<Digit digit="6" string="sechs" />
				<Digit digit="7" string="sieben" />
				<Digit digit="8" string="acht" />
				<Digit digit="9" string="neun" />
			</Group>
			<Group level="2">
				<Digit digit="0" string="" buildString="*" />
				<Digit digit="1" string="zehn" buildString="*zehn" />
				<Digit digit="2" string="zwanzig" buildString="*undzwanzig" />
                                <Digit digit="3" string="dreißig" buildString="*unddreißig" />
				<Digit digit="4" string="vierzig" buildString="*undvierzig" />
				<Digit digit="5" string="fünfzig" buildString="*undfünfzig" />
				<Digit digit="6" string="sechzig" buildString="*undsechzig" />
				<Digit digit="7" string="siebzig" buildString="*undsiebzig" />
                                <Digit digit="8" string="achtzig" buildString="undachtzig" />
				<Digit digit="9" string="neunzig" buildString="*undneunzig" />
			</Group>
			<Group level="3">
				<Digit digit="0" string="" buildString="*" />
				<Digit digit="1" string="einhundert" buildString="einhundert*" />
				<Digit digit="2" string="zweihundert" buildString="zweihundert*" />
				<Digit digit="3" string="dreihundert" buildString="dreihundert*" />
				<Digit digit="4" string="vierhundert" buildString="vierhundert*" />
				<Digit digit="5" string="fünfhundert" buildString="fünfhundert*" />
				<Digit digit="6" string="sechshundert" buildString="sechshundert*" />
				<Digit digit="7" string="siebenhundert" buildString="siebenhundert*" />
				<Digit digit="8" string="achthundert" buildString="achthundert*" />
				<Digit digit="9" string="neunhundert" buildString="neunhundert*" />
			</Group>
		</Groups>
		<NumberScale firstLetterUpperCase="true">
			<StaticNames>
				<Scale value="0" string=""/>
				<Scale value="1" string="tausend"/>
			</StaticNames>
			<Suffixes>
				<Suffix>on(en)</Suffix>
				<Suffix>arde(n)</Suffix>
			</Suffixes>
			<TensPrefixes>
				<Digit digit="0" string=""/>
				<Digit digit="1" string="(n)dezi"/>
				<Digit digit="2" string="(ms)vingti"/>
				<Digit digit="3" string="(ns)triginta"/>
				<Digit digit="4" string="(ns)quadraginta"/>
				<Digit digit="5" string="(ns)quinquaginta"/>
				<Digit digit="6" string="(n)sexaginta"/>
				<Digit digit="7" string="(n)septuaginta"/>
				<Digit digit="8" string="(mxs)octoginta"/>
				<Digit digit="9" string="nonaginta"/>
			</TensPrefixes>
		</NumberScale>
		<Replacements>
			<!--Replacement oldValue="ein tausend" newValue="tausend" /-->
		</Replacements>
		<Exceptions>
			<Number value="11" string="elf" />
			<Number value="12" string="zwölf" />
			<Number value="16" string="sechzehn" />
			<Number value="17" string="siebzehn" />
		</Exceptions>
		<LanguageSpecifics>GermanNumberToStringLanguageSpecifics</LanguageSpecifics>
		<Variants>
			<!--
			  Déclinaison de "ein" (seul chiffre variable en allemand).
			  Les mots composés (einundzwanzig…) ne sont pas déclinés.

			  Ordre des règles : genus=feminin doit être déclaré EN PREMIER car
			  les règles de kasus=dativ/genitiv à 1 contrainte cherchent "ein".
			  Si genus=feminin transforme "ein"→"eine" en premier, les surcharges
			  à 2 contraintes (kasus+genus=feminin) utilisent correctement "eine".

			  Tableau complet des formes :
			    Nominativ : maskulin=ein→eins*, feminin=eine, neutrum=ein→eins*
			    Akkusativ : maskulin=einen, feminin=eine, neutrum=ein→eins*
			    Dativ     : maskulin=einem, feminin=einer, neutrum=einem
			    Genitiv   : maskulin=eines, feminin=einer, neutrum=eines

			  * GermanNumberToStringLanguageSpecifics convertit "ein" seul → "eins"
			    (forme de comptage). Les formes adjectivales "ein" et "ein" (Akk Neutr)
			    deviennent aussi "eins" car indiscernables sans contexte syntaxique.
			-->
			<Dimension name="genus" values="maskulin,feminin,neutrum" />
			<Dimension name="kasus" values="nominativ,akkusativ,dativ,genitiv" />

			<!-- ── 1 contrainte ── -->

			<!-- genus=feminin : Nom/Akk feminin → "eine" -->
			<Variant genus="feminin">
				<Replacement oldValue="ein" newValue="eine" scope="LastWord" />
			</Variant>

			<!-- kasus=dativ : maskulin + neutrum → "einem"
			     (feminin+dativ est corrigé en "einer" par la règle à 2 contraintes) -->
			<Variant kasus="dativ">
				<Replacement oldValue="ein" newValue="einem" scope="LastWord" />
			</Variant>

			<!-- kasus=genitiv : maskulin + neutrum → "eines"
			     (feminin+genitiv est corrigé en "einer" par la règle à 2 contraintes) -->
			<Variant kasus="genitiv">
				<Replacement oldValue="ein" newValue="eines" scope="LastWord" />
			</Variant>

			<!-- ── 2 contraintes (surcharge les règles à 1 contrainte) ── -->

			<!-- Akkusativ maskulin → "einen" -->
			<Variant kasus="akkusativ" genus="maskulin">
				<Replacement oldValue="ein" newValue="einen" scope="LastWord" />
			</Variant>

			<!-- Dativ feminin → "einer"
			     genus=feminin a déjà transformé "ein"→"eine", d'où oldValue="eine" -->
			<Variant kasus="dativ" genus="feminin">
				<Replacement oldValue="eine" newValue="einer" scope="LastWord" />
			</Variant>

			<!-- Genitiv feminin → "einer" (même logique) -->
			<Variant kasus="genitiv" genus="feminin">
				<Replacement oldValue="eine" newValue="einer" scope="LastWord" />
			</Variant>
		</Variants>
	</Language>
</Numbers>
