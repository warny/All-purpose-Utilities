<?xml version="1.0" encoding="utf-8" ?>
<Numbers xmlns="Utils/NumberConvertionConfiguration.xsd">
        <Language
                groupSize="3"
                separator=" "
                groupSeparator=""
                zero="zero"
                minus="menys *"
                decimalSeparator="coma"
                fractionSeparator="partit per"
        >
                <Culture>CA</Culture>
                <Culture>ca-ES</Culture>
                <Culture>ca-ES-valencia</Culture>
                <Groups>
                        <Group level="1">
                                <Digit digit="0" string="" />
                                <Digit digit="1" string="un" />
                                <Digit digit="2" string="dos" />
                                <Digit digit="3" string="tres" />
                                <Digit digit="4" string="quatre" />
                                <Digit digit="5" string="cinc" />
                                <Digit digit="6" string="sis" />
                                <Digit digit="7" string="set" />
                                <Digit digit="8" string="vuit" />
                                <Digit digit="9" string="nou" />
                        </Group>
                        <Group level="2">
                                <Digit digit="0" string="" buildString="*" />
                                <Digit digit="1" string="deu" buildString="deu i *" />
                                <Digit digit="2" string="vint" buildString="vint-i-*" />
                                <Digit digit="3" string="trenta" buildString="trenta-*" />
                                <Digit digit="4" string="quaranta" buildString="quaranta-*" />
                                <Digit digit="5" string="cinquanta" buildString="cinquanta-*" />
                                <Digit digit="6" string="seixanta" buildString="seixanta-*" />
                                <Digit digit="7" string="setanta" buildString="setanta-*" />
                                <Digit digit="8" string="vuitanta" buildString="vuitanta-*" />
                                <Digit digit="9" string="noranta" buildString="noranta-*" />
                        </Group>
                        <Group level="3">
                                <Digit digit="0" string="" buildString="*" />
                                <Digit digit="1" string="cent" buildString="cent *" />
                                <Digit digit="2" string="dos-cents" buildString="dos-cents *" />
                                <Digit digit="3" string="tres-cents" buildString="tres-cents *" />
                                <Digit digit="4" string="quatre-cents" buildString="quatre-cents *" />
                                <Digit digit="5" string="cinc-cents" buildString="cinc-cents *" />
                                <Digit digit="6" string="sis-cents" buildString="sis-cents *" />
                                <Digit digit="7" string="set-cents" buildString="set-cents *" />
                                <Digit digit="8" string="vuit-cents" buildString="vuit-cents *" />
                                <Digit digit="9" string="nou-cents" buildString="nou-cents *" />
                        </Group>
                </Groups>
                <NumberScale firstLetterUpperCase="false">
                        <StaticNames>
                                <Scale value="0" string="" />
                                <Scale value="1" string="mil" />
                                <Scale value="2" string="milió(ns)" />
                                <Scale value="3" string="mil milió(ns)" />
                        </StaticNames>
                        <Suffixes>
                                <Suffix>(ó|ons)</Suffix>
                        </Suffixes>
                </NumberScale>
                <Replacements>
                        <Replacement oldValue="un mil" newValue="mil" />
                </Replacements>
		<Exceptions>
			<Number value="11" string="onze" />
			<Number value="12" string="dotze" />
			<Number value="13" string="tretze" />
			<Number value="14" string="catorze" />
			<Number value="15" string="quinze" />
			<Number value="16" string="setze" />
			<Number value="17" string="disset" />
			<Number value="18" string="divuit" />
			<Number value="19" string="dinou" />
		</Exceptions>
		<Variants>
			<!--
			  En catalan, les chiffres 1 (un/una) et 2 (dos/dues) varient en genre,
			  ainsi que les deux-cents (dos-cents/dues-centes). Les autres centaines
			  sont invariables. Les composés des dizaines utilisent des tirets
			  (vint-i-un, trenta-un…) : le tiret est une frontière de mot pour
			  LastWord, donc la règle s'applique correctement aux composés.
			-->
			<Dimension name="gender" values="masculí,femení" />

			<Variant gender="femení">
				<!-- Unités variables en genre (fonctionne sur les composés grâce aux tirets) -->
				<Replacement oldValue="un"  newValue="una"  scope="LastWord" />
				<Replacement oldValue="dos" newValue="dues" scope="LastWord" />
				<!-- Seule la centaine de 200 a une forme féminine en catalan -->
				<Replacement oldValue="dos-cents" newValue="dues-centes" scope="Anywhere" />
			</Variant>
		</Variants>
	</Language>
</Numbers>
