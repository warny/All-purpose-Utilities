<?xml version="1.0" encoding="utf-8" ?>
<Numbers xmlns="Utils/NumberConvertionConfiguration.xsd">
    <Language
        groupSize="3"
        separator=" "
        groupSeparator=""
        zero="zero"
        minus="minus *"
        decimalSeparator="przecinek"
        fractionSeparator="przez"
    >
        <Culture>PL</Culture>
        <Groups>
            <Group level="1">
                <Digit digit="0" string="" />
                <Digit digit="1" string="jeden" />
                <Digit digit="2" string="dwa" />
                <Digit digit="3" string="trzy" />
                <Digit digit="4" string="cztery" />
                <Digit digit="5" string="pięć" />
                <Digit digit="6" string="sześć" />
                <Digit digit="7" string="siedem" />
                <Digit digit="8" string="osiem" />
                <Digit digit="9" string="dziewięć" />
            </Group>
            <Group level="2">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="dziesięć" buildString="dziesięć *" />
                <Digit digit="2" string="dwadzieścia" buildString="dwadzieścia *" />
                <Digit digit="3" string="trzydzieści" buildString="trzydzieści *" />
                <Digit digit="4" string="czterdzieści" buildString="czterdzieści *" />
                <Digit digit="5" string="pięćdziesiąt" buildString="pięćdziesiąt *" />
                <Digit digit="6" string="sześćdziesiąt" buildString="sześćdziesiąt *" />
                <Digit digit="7" string="siedemdziesiąt" buildString="siedemdziesiąt *" />
                <Digit digit="8" string="osiemdziesiąt" buildString="osiemdziesiąt *" />
                <Digit digit="9" string="dziewięćdziesiąt" buildString="dziewięćdziesiąt *" />
            </Group>
            <Group level="3">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="sto" buildString="sto *" />
                <Digit digit="2" string="dwieście" buildString="dwieście *" />
                <Digit digit="3" string="trzysta" buildString="trzysta *" />
                <Digit digit="4" string="czterysta" buildString="czterysta *" />
                <Digit digit="5" string="pięćset" buildString="pięćset *" />
                <Digit digit="6" string="sześćset" buildString="sześćset *" />
                <Digit digit="7" string="siedemset" buildString="siedemset *" />
                <Digit digit="8" string="osiemset" buildString="osiemset *" />
                <Digit digit="9" string="dziewięćset" buildString="dziewięćset *" />
            </Group>
        </Groups>
        <NumberScale firstLetterUpperCase="false">
            <StaticNames>
                <Scale value="0" string="" />
                <Scale value="1" string="tysiąc" />
            </StaticNames>
            <Suffixes>
                <Suffix>milion</Suffix>
            </Suffixes>
        </NumberScale>
        <Replacements>
            <Replacement oldValue="jeden tysiąc" newValue="tysiąc" />
        </Replacements>
        <Exceptions>
            <Number value="11" string="jedenaście" />
            <Number value="12" string="dwanaście" />
            <Number value="13" string="trzynaście" />
            <Number value="14" string="czternaście" />
            <Number value="15" string="piętnaście" />
            <Number value="16" string="szesnaście" />
            <Number value="17" string="siedemnaście" />
            <Number value="18" string="osiemnaście" />
            <Number value="19" string="dziewiętnaście" />
        </Exceptions>
        <Ordinals>
            <!-- Nominatif masculin singulier — tous les stems diffèrent des cardinaux -->
            <!-- Unités -->
            <Ordinal from="jeden"    to="pierwszy" />
            <Ordinal from="dwa"      to="drugi" />
            <Ordinal from="trzy"     to="trzeci" />
            <Ordinal from="cztery"   to="czwarty" />
            <Ordinal from="pięć"     to="piąty" />
            <Ordinal from="sześć"    to="szósty" />
            <Ordinal from="siedem"   to="siódmy" />
            <Ordinal from="osiem"    to="ósmy" />
            <Ordinal from="dziewięć" to="dziewiąty" />
            <Ordinal from="dziesięć" to="dziesiąty" />
            <!-- Exceptions 11-19 -->
            <Ordinal from="jedenaście"    to="jedenasty" />
            <Ordinal from="dwanaście"     to="dwunasty" />
            <Ordinal from="trzynaście"    to="trzynasty" />
            <Ordinal from="czternaście"   to="czternasty" />
            <Ordinal from="piętnaście"    to="piętnasty" />
            <Ordinal from="szesnaście"    to="szesnasty" />
            <Ordinal from="siedemnaście"  to="siedemnasty" />
            <Ordinal from="osiemnaście"   to="osiemnasty" />
            <Ordinal from="dziewiętnaście" to="dziewiętnasty" />
            <!-- Dizaines -->
            <Ordinal from="dwadzieścia"    to="dwudziesty" />
            <Ordinal from="trzydzieści"    to="trzydziesty" />
            <Ordinal from="czterdzieści"   to="czterdziesty" />
            <Ordinal from="pięćdziesiąt"   to="pięćdziesiąty" />
            <Ordinal from="sześćdziesiąt"  to="sześćdziesiąty" />
            <Ordinal from="siedemdziesiąt" to="siedemdziesiąty" />
            <Ordinal from="osiemdziesiąt"  to="osiemdziesiąty" />
            <Ordinal from="dziewięćdziesiąt" to="dziewięćdziesiąty" />
            <!-- Centaines -->
            <Ordinal from="sto"         to="setny" />
            <Ordinal from="dwieście"    to="dwusetny" />
            <Ordinal from="trzysta"     to="trzechsetny" />
            <Ordinal from="czterysta"   to="czterosetny" />
            <Ordinal from="pięćset"     to="pięćsetny" />
            <Ordinal from="sześćset"    to="sześćsetny" />
            <Ordinal from="siedemset"   to="siedemsetny" />
            <Ordinal from="osiemset"    to="osiemsetny" />
            <Ordinal from="dziewięćset" to="dziewięćsetny" />
            <!-- Millier -->
            <Ordinal from="tysiąc" to="tysięczny" />
        </Ordinals>
    </Language>
</Numbers>
