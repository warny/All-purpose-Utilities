<?xml version="1.0" encoding="utf-8" ?>
<Numbers xmlns="Utils/NumberConvertionConfiguration.xsd">
    <Language
        groupSize="3"
        separator=" "
        groupSeparator=""
        zero="nolla"
        minus="miinus *"
        decimalSeparator="pilkku"
        fractionSeparator="yli"
        maxNumber="999999999"
    >
        <Culture>FI</Culture>
        <Groups>
            <Group level="1">
                <Digit digit="0" string="" />
                <Digit digit="1" string="yksi" />
                <Digit digit="2" string="kaksi" />
                <Digit digit="3" string="kolme" />
                <Digit digit="4" string="neljä" />
                <Digit digit="5" string="viisi" />
                <Digit digit="6" string="kuusi" />
                <Digit digit="7" string="seitsemän" />
                <Digit digit="8" string="kahdeksan" />
                <Digit digit="9" string="yhdeksän" />
            </Group>
            <Group level="2">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="kymmenen" buildString="kymmenen *" />
                <Digit digit="2" string="kaksikymmentä" buildString="kaksikymmentä *" />
                <Digit digit="3" string="kolmekymmentä" buildString="kolmekymmentä *" />
                <Digit digit="4" string="neljäkymmentä" buildString="neljäkymmentä *" />
                <Digit digit="5" string="viisikymmentä" buildString="viisikymmentä *" />
                <Digit digit="6" string="kuusikymmentä" buildString="kuusikymmentä *" />
                <Digit digit="7" string="seitsemänkymmentä" buildString="seitsemänkymmentä *" />
                <Digit digit="8" string="kahdeksankymmentä" buildString="kahdeksankymmentä *" />
                <Digit digit="9" string="yhdeksänkymmentä" buildString="yhdeksänkymmentä *" />
            </Group>
            <Group level="3">
                <Digit digit="0" string="" buildString="*" />
                <Digit digit="1" string="sata" buildString="sata *" />
                <Digit digit="2" string="kaksisataa" buildString="kaksisataa *" />
                <Digit digit="3" string="kolmesataa" buildString="kolmesataa *" />
                <Digit digit="4" string="neljäsataa" buildString="neljäsataa *" />
                <Digit digit="5" string="viisisataa" buildString="viisisataa *" />
                <Digit digit="6" string="kuusisataa" buildString="kuusisataa *" />
                <Digit digit="7" string="seitsemänsataa" buildString="seitsemänsataa *" />
                <Digit digit="8" string="kahdeksansataa" buildString="kahdeksansataa *" />
                <Digit digit="9" string="yhdeksänsataa" buildString="yhdeksänsataa *" />
            </Group>
        </Groups>
        <NumberScale firstLetterUpperCase="false">
            <StaticNames>
                <Scale value="0" string="" />
                <Scale value="1" string="tuhat" />
            </StaticNames>
            <Suffixes>
                <Suffix>miljoona</Suffix>
            </Suffixes>
        </NumberScale>
        <Exceptions>
            <Number value="11" string="yksitoista" />
            <Number value="12" string="kaksitoista" />
            <Number value="13" string="kolmetoista" />
            <Number value="14" string="neljätoista" />
            <Number value="15" string="viisitoista" />
            <Number value="16" string="kuusitoista" />
            <Number value="17" string="seitsemäntoista" />
            <Number value="18" string="kahdeksantoista" />
            <Number value="19" string="yhdeksäntoista" />
        </Exceptions>
        <Variants>
            <!--
              Finnish declines numbers across 15 cases (sijamuoto).
              Nominatiivi (default), partitiivi and genetiivi are implemented.

              PARTITIIVI
                Units (yksi…yhdeksän) change via LastWord.
                Compound tens (kaksikymmentä…) and compound hundreds
                (kaksisataa…) are ALREADY in a partitive-compatible form
                in the current configuration: no additional rules are needed.
                Exceptions 11-19 change via Anywhere because they can
                appear in intermediate positions.

              GENETIIVI
                Units change via LastWord.
                Compound tens and hundreds are replaced entirely via Anywhere
                (e.g. kaksikymmentä → kahdenkymmenen).
                Isolated scale words (sata, tuhat) use Standalone: an Anywhere
                rule would corrupt compound forms (kaksisataa, etc.).
                Limitation: in a compound like "sata yksi" (101), "sata" stays
                unchanged because it is neither the last word nor alone in the text.
                seitsemän/kahdeksan/yhdeksän and their derivatives are invariable
                in the genitive (same form as nominative).
            -->
            <Dimension name="sijamuoto" values="nominatiivi,partitiivi,genetiivi" />

            <!-- ── Partitiivi ─────────────────────────────────────────────── -->
            <Variant sijamuoto="partitiivi">
                <!-- Units (LastWord) -->
                <Replacement oldValue="yksi"      newValue="yhtä"      scope="LastWord" />
                <Replacement oldValue="kaksi"     newValue="kahta"     scope="LastWord" />
                <Replacement oldValue="kolme"     newValue="kolmea"    scope="LastWord" />
                <Replacement oldValue="neljä"     newValue="neljää"    scope="LastWord" />
                <Replacement oldValue="viisi"     newValue="viittä"    scope="LastWord" />
                <Replacement oldValue="kuusi"     newValue="kuutta"    scope="LastWord" />
                <Replacement oldValue="seitsemän" newValue="seitsemää" scope="LastWord" />
                <Replacement oldValue="kahdeksan" newValue="kahdeksaa" scope="LastWord" />
                <Replacement oldValue="yhdeksän"  newValue="yhdeksää"  scope="LastWord" />
                <!-- Isolated scale words (LastWord) -->
                <Replacement oldValue="kymmenen" newValue="kymmentä"  scope="LastWord" />
                <Replacement oldValue="sata"     newValue="sataa"     scope="LastWord" />
                <Replacement oldValue="tuhat"    newValue="tuhatta"   scope="LastWord" />
                <Replacement oldValue="miljoona" newValue="miljoonaa" scope="LastWord" />
                <!-- Exceptions 11-19 (Anywhere: compound words, variable position) -->
                <Replacement oldValue="yksitoista"      newValue="yhtätoista"      scope="Anywhere" />
                <Replacement oldValue="kaksitoista"     newValue="kahtatoista"     scope="Anywhere" />
                <Replacement oldValue="kolmetoista"     newValue="kolmeatoista"    scope="Anywhere" />
                <Replacement oldValue="neljätoista"     newValue="neljäätoista"    scope="Anywhere" />
                <Replacement oldValue="viisitoista"     newValue="viittätoista"    scope="Anywhere" />
                <Replacement oldValue="kuusitoista"     newValue="kuuttatoista"    scope="Anywhere" />
                <Replacement oldValue="seitsemäntoista" newValue="seitsemäätoista" scope="Anywhere" />
                <Replacement oldValue="kahdeksantoista" newValue="kahdeksaatoista" scope="Anywhere" />
                <Replacement oldValue="yhdeksäntoista"  newValue="yhdeksäätoista"  scope="Anywhere" />
            </Variant>

            <!-- ── Genetiivi ──────────────────────────────────────────────── -->
            <Variant sijamuoto="genetiivi">
                <!-- Units (LastWord) — seitsemän/kahdeksan/yhdeksän are invariable -->
                <Replacement oldValue="yksi"  newValue="yhden"  scope="LastWord" />
                <Replacement oldValue="kaksi" newValue="kahden" scope="LastWord" />
                <Replacement oldValue="kolme" newValue="kolmen" scope="LastWord" />
                <Replacement oldValue="neljä" newValue="neljän" scope="LastWord" />
                <Replacement oldValue="viisi" newValue="viiden" scope="LastWord" />
                <Replacement oldValue="kuusi" newValue="kuuden" scope="LastWord" />
                <!-- Isolated scale words (Standalone: safe; Anywhere would corrupt compound forms) -->
                <Replacement oldValue="sata"     newValue="sadan"     scope="Standalone" />
                <Replacement oldValue="tuhat"    newValue="tuhannen"  scope="Standalone" />
                <Replacement oldValue="miljoona" newValue="miljoonan" scope="LastWord"   />
                <!-- Compound tens (Anywhere: the entire compound is replaced) -->
                <Replacement oldValue="kaksikymmentä"     newValue="kahdenkymmenen"    scope="Anywhere" />
                <Replacement oldValue="kolmekymmentä"     newValue="kolmenkymmenen"    scope="Anywhere" />
                <Replacement oldValue="neljäkymmentä"     newValue="neljänkymmenen"    scope="Anywhere" />
                <Replacement oldValue="viisikymmentä"     newValue="viidenkymmenen"    scope="Anywhere" />
                <Replacement oldValue="kuusikymmentä"     newValue="kuudenkymmenen"    scope="Anywhere" />
                <Replacement oldValue="seitsemänkymmentä" newValue="seitsemänkymmenen" scope="Anywhere" />
                <Replacement oldValue="kahdeksankymmentä" newValue="kahdeksankymmenen" scope="Anywhere" />
                <Replacement oldValue="yhdeksänkymmentä"  newValue="yhdeksänkymmenen"  scope="Anywhere" />
                <!-- Compound hundreds (Anywhere) -->
                <Replacement oldValue="kaksisataa"     newValue="kahdensadan"    scope="Anywhere" />
                <Replacement oldValue="kolmesataa"     newValue="kolmensadan"    scope="Anywhere" />
                <Replacement oldValue="neljäsataa"     newValue="neljänsadan"    scope="Anywhere" />
                <Replacement oldValue="viisisataa"     newValue="viidensadan"    scope="Anywhere" />
                <Replacement oldValue="kuusisataa"     newValue="kuudensadan"    scope="Anywhere" />
                <Replacement oldValue="seitsemänsataa" newValue="seitsemänsadan" scope="Anywhere" />
                <Replacement oldValue="kahdeksansataa" newValue="kahdeksansadan" scope="Anywhere" />
                <Replacement oldValue="yhdeksänsataa"  newValue="yhdeksänsadan"  scope="Anywhere" />
                <!-- Exceptions 11-16 (Anywhere) — 17-19 invariable in genitive -->
                <Replacement oldValue="yksitoista"  newValue="yhdentoista"  scope="Anywhere" />
                <Replacement oldValue="kaksitoista" newValue="kahdentoista" scope="Anywhere" />
                <Replacement oldValue="kolmetoista" newValue="kolmentoista" scope="Anywhere" />
                <Replacement oldValue="neljätoista" newValue="neljäntoista" scope="Anywhere" />
                <Replacement oldValue="viisitoista" newValue="viidentoista" scope="Anywhere" />
                <Replacement oldValue="kuusitoista" newValue="kuudentoista" scope="Anywhere" />
            </Variant>
        </Variants>
    </Language>
</Numbers>
